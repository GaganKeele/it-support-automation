      "name": "AI detects issue type + confidence score"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst seen = [], valid = [];\n\nfor (const item of items) {\n  const d  = item.json;\n  const ts = new Date(d.timestamp).getTime();\n\n  const isDup = seen.some(s =>\n    s.email      === d.email &&\n    s.issue_type === d.issue_type &&\n    Math.abs(ts  - s.ts) <= 86400000\n  );\n\n  if (isDup) {\n    // just skip duplicates\n  } else {\n    seen.push({ email: d.email, issue_type: d.issue_type, ts });\n    valid.push({ json: d });\n  }\n}\nreturn valid;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
