    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst seenIds = new Set();\n\nreturn items.map(item => {\n  const d = item.json;\n  let tid = (d.ticket_id || '').toString().trim();\n  if (!tid || tid === 'nan' || seenIds.has(tid)) {\n    tid = 'T-' + Math.random().toString(36).substr(2, 8).toUpperCase();\n  }\n  seenIds.add(tid);\n  return { json: { ...d, ticket_id: tid }};\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
