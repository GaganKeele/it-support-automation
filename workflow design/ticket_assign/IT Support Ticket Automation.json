      "id": "0af37810-ed6a-4bff-88af-5131f8904ea6",
      "name": "FIX TICKET IDs1"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst emailRegex = /^[\\w\\.\\-]+@[\\w\\.\\-]+\\.\\w+$/;\nconst validPriorities = ['high', 'medium', 'low'];\nconst validIssues = ['wifi', 'login', 'software', 'hardware', 'other'];\n\nreturn items.map(item => {\n  const d = item.json;\n  let reject_reason = null;\n\n  if (!emailRegex.test(d.email || '')) {\n    reject_reason = 'Invalid email format';\n  }\n\n  return { json: {\n    ...d,\n    reject_reason,\n    needsPriorityFix: !validPriorities.includes(d.priority || ''),\n    needsIssueFix:    !validIssues.includes(d.issue_type || ''),\n  }};\n});"
      },
