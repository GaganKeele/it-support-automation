    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst seen = [], valid = [];\n\nfor (const item of items) {\n  const d = item.json;\n  const rawTs = String(d.timestamp || '').replace(' ', 'T');\n  const ts = new Date(rawTs).getTime() || Date.now();\n\n  const isDup = seen.some(s =>\n    s.email      === d.email &&\n    s.issue_type === d.issue_type &&\n    Math.abs(ts  - s.ts) <= 86400000\n  );\n\n  if (!isDup) {\n    seen.push({ email: d.email, issue_type: d.issue_type, ts });\n    valid.push({ json: d });\n  }\n}\nreturn valid;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        5072,
        832
      ],
      "id": "eec675c9-3b7e-4b67-a69f-3bda22ff1b33",
      "name": "Deduplicate1"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nconst routing = {\n  wifi:     'Network',\n  login:    'IT Support',\n  software: 'Applications',\n  hardware: 'Infrastructure',\n  other:    'General'\n};\n\nconst slaHours = { high: 4, medium: 24, low: 72 };\n\nreturn items.map(item => {\n  const d   = item.json;\n  const raw = String(d.timestamp || '').replace(' ', 'T');\n  const ts  = new Date(raw);\n  const hrs = slaHours[d.priority] || 72;\n  const sla = new Date((isNaN(ts) ? new Date() : ts).getTime() + hrs * 3600000);\n\n  return { json: {\n    ...d,\n    assigned_team: routing[d.issue_type] || 'General',\n    sla_deadline:  sla.toISOString().replace('T', ' ').substr(0, 19),\n  }};\n});"
      },
